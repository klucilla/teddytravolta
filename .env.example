# ===== Teddy Travolta Live - Configuracao =====
# Copie este arquivo para .env e preencha os valores.

# Usuario do TikTok (sem @) que sera monitorado ao vivo
TIKTOK_USERNAME=seu_usuario_aqui

# Modo simulador: true = gera presentes falsos a cada 10s (teste sem live)
SIMULATOR=true

# Intervalo do simulador em milissegundos
SIMULATOR_INTERVAL_MS=10000

# ===== OBS WebSocket (OBS 30+, Ferramentas > Configuracoes do WebSocket) =====
OBS_HOST=127.0.0.1
OBS_PORT=4455
OBS_PASSWORD=

# Nomes das cenas no OBS
# Uma ou varias cenas de danca separadas por virgula (o Teddy alterna entre elas).
# Pode incluir o moonwalk aqui para ele aparecer no rodizio (alem do bonus por like).
OBS_SCENE_DANCE=danca_loop,danca_loop2,danca_loop3,moonwalk
OBS_SCENE_CELEBRATION=comemoracao
# Alternar entre as cenas de danca a cada N segundos quando ocioso (0 desliga)
DANCE_ROTATE_SECONDS=25
# Cena do urso falando calmamente, usada em follows/likes (deixe vazio para desativar)
OBS_SCENE_TALK=fala
# Cena do urso indo ao bar, usada em compartilhamentos (deixe vazio para desativar)
OBS_SCENE_SHARE=bar
# Cena do urso dando boas-vindas a quem entra na sala (deixe vazio para desativar)
OBS_SCENE_WELCOME=boasvindas
# Dar boas-vindas a cada N entradas na sala (lives movimentadas têm muitas). 0 desliga.
WELCOME_EVERY=10
# Cena do urso fazendo moonwalk em rajada de likes (deixe vazio para desativar)
OBS_SCENE_MOONWALK=moonwalk

# ===== TTS (Edge TTS - gratuito, sem API key) =====
# Vozes pt-BR: pt-BR-AntonioNeural (masculina), pt-BR-FranciscaNeural (feminina),
# pt-BR-ThalitaMultilingualNeural (feminina multilingue)
TTS_VOICE=pt-BR-AntonioNeural

# ===== Overlay =====
OVERLAY_PORT=3000
# Host do overlay. Padrao 127.0.0.1 (so esta maquina — seguro). So mude para
# 0.0.0.0 se o OBS rodar em OUTRA maquina da sua rede local.
OVERLAY_HOST=127.0.0.1

# Bordão "cantado" por TTS (á á á stayin {nome}!) antes da frase, em presentes de 100+ coins
CHANT=false
# Vinheta cantada (MP3, ex.: do Suno) antes da frase em presentes de 100+ coins
# Tem prioridade sobre o CHANT. Deixe vazio (ou sem o arquivo) para desativar.
JINGLE_FILE=assets/musica/jingle.mp3

# ===== Agradecimentos extras =====
# Agradecer novos seguidores (true/false)
THANK_FOLLOWS=true
# Agradecer rajadas de likes com moonwalk (true/false)
THANK_LIKES=true
# Likes que UMA pessoa precisa acumular para ganhar o moonwalk (por pessoa)
LIKES_THRESHOLD=30
# Diagnostico: loga cada like recebido no console (deixe false em producao)
LIKES_DEBUG=false

# ===== Interatividade / engajamento =====
# Descarta boas-vindas se ja houver esta qtde de itens esperando na fila (0 = nunca)
QUEUE_DROP_WELCOME_AFTER=3
# Se ninguem interagir por N segundos, o Teddy puxa papo no chat (0 desliga)
IDLE_PROMPT_SECONDS=40
# Comemora ao bater cada multiplo de N espectadores na sala (0 desliga)
MILESTONE_EVERY=10

# ===== Meta da live (barra de progresso no overlay) =====
# Tipo: followers (novos seguidores da live), coins (presentes) ou off
META_TYPE=followers
META_TARGET=5
# Quando bate, a proxima meta sobe este tanto
META_STEP=5

# ===== Desafio-relampago (o 1o a mandar o gatilho no chat vence) =====
# Lanca um desafio a cada N minutos, em momento tranquilo (0 desliga)
CHALLENGE_EVERY_MIN=6
# Janela para alguem vencer, em segundos
CHALLENGE_WINDOW_SEC=90

# ===== IA local (Ollama) — opcional, deixe LLM_ENABLED=false para desligar =====
# Gera frases variadas e faz o Teddy responder comentarios. Precisa do Ollama rodando.
LLM_ENABLED=false
LLM_HOST=http://localhost:11434
LLM_MODEL=qwen2.5:7b-instruct
# Tempo maximo de espera por resposta da IA (ms); se estourar, usa fallback
LLM_TIMEOUT_MS=8000
# Mantem o modelo carregado no Ollama por este tempo (evita recarregar/cold start)
LLM_KEEP_ALIVE=30m
# Usar a IA para gerar as frases de agradecimento (fallback: listas fixas)
LLM_PHRASES=true
# Teddy responder comentarios do chat por voz (com moderacao)
LLM_COMMENTS=true
# Com publico GRANDE, responde so 1 a cada N comentarios (chat fica intenso)
LLM_COMMENT_EVERY=4
# Com espectadores <= este valor, responde TODOS os comentarios (publico pequeno)
LLM_COMMENT_BUSY_VIEWERS=20
